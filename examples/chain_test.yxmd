<?xml version="1.0"?>
<AlteryxDocument yxmdVer="2022.1">
  <Nodes>
    <!-- Input -->
    <Node ToolID="1">
      <GuiSettings Plugin="AlteryxBasePluginsGui.DbFileInput.DbFileInput">
        <Position x="54" y="108"/>
      </GuiSettings>
      <Properties><Configuration><File>C:\Data\sales.csv</File><RecordLimit>0</RecordLimit></Configuration></Properties>
    </Node>
    <!-- Filter chain (3 nodes) -->
    <Node ToolID="2">
      <GuiSettings Plugin="AlteryxBasePluginsGui.Filter.Filter">
        <Position x="216" y="108"/>
      </GuiSettings>
      <Properties><Configuration><Expression>[Country] = "Japan"</Expression></Configuration></Properties>
    </Node>
    <Node ToolID="3">
      <GuiSettings Plugin="AlteryxBasePluginsGui.Filter.Filter">
        <Position x="378" y="108"/>
      </GuiSettings>
      <Properties><Configuration><Expression>[Status] = "Active"</Expression></Configuration></Properties>
    </Node>
    <Node ToolID="4">
      <GuiSettings Plugin="AlteryxBasePluginsGui.Filter.Filter">
        <Position x="540" y="108"/>
      </GuiSettings>
      <Properties><Configuration><Expression>[Revenue] > 0</Expression></Configuration></Properties>
    </Node>
    <!-- Formula chain (4 nodes) -->
    <Node ToolID="5">
      <GuiSettings Plugin="AlteryxBasePluginsGui.Formula.Formula">
        <Position x="702" y="108"/>
      </GuiSettings>
      <Properties><Configuration><Expression>[Price] * [Qty]</Expression></Configuration></Properties>
    </Node>
    <Node ToolID="6">
      <GuiSettings Plugin="AlteryxBasePluginsGui.Formula.Formula">
        <Position x="864" y="108"/>
      </GuiSettings>
      <Properties><Configuration><Expression>[Total] * 1.10</Expression></Configuration></Properties>
    </Node>
    <Node ToolID="7">
      <GuiSettings Plugin="AlteryxBasePluginsGui.Formula.Formula">
        <Position x="1026" y="108"/>
      </GuiSettings>
      <Properties><Configuration><Expression>DateTimeFormat([Date], "%Y-%m")</Expression></Configuration></Properties>
    </Node>
    <Node ToolID="8">
      <GuiSettings Plugin="AlteryxBasePluginsGui.Formula.Formula">
        <Position x="1188" y="108"/>
      </GuiSettings>
      <Properties><Configuration><Expression>IIF([TaxTotal] > 1000, "Large", "Small")</Expression></Configuration></Properties>
    </Node>
    <!-- Single Select (no chain) -->
    <Node ToolID="9">
      <GuiSettings Plugin="AlteryxBasePluginsGui.AlteryxSelect.AlteryxSelect">
        <Position x="1350" y="108"/>
      </GuiSettings>
      <Properties><Configuration><OrderChanged>False</OrderChanged></Configuration></Properties>
    </Node>
    <!-- Output -->
    <Node ToolID="10">
      <GuiSettings Plugin="AlteryxBasePluginsGui.DbFileOutput.DbFileOutput">
        <Position x="1512" y="108"/>
      </GuiSettings>
      <Properties><Configuration><File>C:\Output\result.xlsx</File></Configuration></Properties>
    </Node>
  </Nodes>
  <Connections>
    <Connection><Origin ToolID="1" Connection="Output"/><Destination ToolID="2" Connection="Input"/></Connection>
    <Connection><Origin ToolID="2" Connection="True"/><Destination ToolID="3" Connection="Input"/></Connection>
    <Connection><Origin ToolID="3" Connection="True"/><Destination ToolID="4" Connection="Input"/></Connection>
    <Connection><Origin ToolID="4" Connection="True"/><Destination ToolID="5" Connection="Input"/></Connection>
    <Connection><Origin ToolID="5" Connection="Output"/><Destination ToolID="6" Connection="Input"/></Connection>
    <Connection><Origin ToolID="6" Connection="Output"/><Destination ToolID="7" Connection="Input"/></Connection>
    <Connection><Origin ToolID="7" Connection="Output"/><Destination ToolID="8" Connection="Input"/></Connection>
    <Connection><Origin ToolID="8" Connection="Output"/><Destination ToolID="9" Connection="Input"/></Connection>
    <Connection><Origin ToolID="9" Connection="Output"/><Destination ToolID="10" Connection="Input"/></Connection>
  </Connections>
</AlteryxDocument>
